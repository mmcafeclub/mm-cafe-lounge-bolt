{
  "name": "LoungeNews",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "description": "Markdown content"
    },
    "image_url": {
      "type": "string"
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    },
    "published_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "title"
  ]
}