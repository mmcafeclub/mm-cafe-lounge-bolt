{
  "name": "Gift",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "points_required": {
      "type": "number"
    },
    "image_url": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "stock": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "points_required"
  ]
}