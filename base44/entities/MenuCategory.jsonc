{
  "name": "MenuCategory",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Category tab name (e.g. Breakfast, Lunch, Drinks)"
    },
    "sort_order": {
      "type": "number",
      "default": 0,
      "description": "Display order of the tab"
    }
  },
  "required": [
    "name"
  ]
}